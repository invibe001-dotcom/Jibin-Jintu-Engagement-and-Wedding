<style>
*, *::before, *::after {
  margin: 0; padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

:root {
  --ivory:      #FBF6EF;
  --ivory-2:    #F4EADD;
  --blush:      #E7B3AD;
  --rose:       #CE8079;
  --rose-deep:  #B5635B;
  --emerald:    #2E5D4E;
  --emerald-dk: #21443A;
  --sage:       #8FAE9B;
  --gold-soft:  #B8975A;
  --ink:        #364A40;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'EB Garamond', serif;
  color: var(--ink);
  overflow-x: hidden;
  min-height: 100vh;
  position: relative;
  background: var(--ivory);
}

/* Soft botanical ambient background (no photos) */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -2;
  background:
    radial-gradient(120% 80% at 12% 0%, rgba(231,179,173,0.40) 0%, rgba(231,179,173,0) 55%),
    radial-gradient(120% 80% at 88% 8%, rgba(143,174,155,0.38) 0%, rgba(143,174,155,0) 55%),
    radial-gradient(140% 100% at 50% 100%, rgba(46,93,78,0.18) 0%, rgba(46,93,78,0) 60%),
    linear-gradient(170deg, #FCF8F2 0%, #F6EDE2 48%, #F1E6D8 100%);
}
/* Faint paper grain veil */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  background-image: radial-gradient(rgba(54,74,64,0.035) 1px, transparent 1px);
  background-size: 4px 4px;
  opacity: 0.6;
}

/* ── FALLING PETALS (signature ambient) ── */
.petal {
  position: fixed;
  top: -8vh;
  width: 14px;
  height: 14px;
  background: radial-gradient(circle at 30% 30%, var(--blush), var(--rose) 75%);
  border-radius: 75% 5% 75% 5%;
  pointer-events: none;
  opacity: 0;
  z-index: 8;
  animation: petalFall linear infinite;
}
@keyframes petalFall {
  0%   { transform: translateY(-10vh) translateX(0) rotate(0deg);   opacity: 0; }
  8%   { opacity: 0.85; }
  50%  { transform: translateY(48vh) translateX(40px) rotate(220deg); }
  90%  { opacity: 0.55; }
  100% { transform: translateY(112vh) translateX(-30px) rotate(440deg); opacity: 0; }
}

/* ── GUEST GREETING BANNER ── */
#guest-banner {
  display: none;
  position: relative;
  z-index: 3;
  text-align: center;
  margin-bottom: 22px;
  animation: softRise 1s ease forwards;
}
@keyframes softRise {
  from { opacity: 0; transform: translateY(-16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.guest-pill {
  display: inline-block;
  padding: 12px 30px 16px;
  border: 1px solid rgba(46,93,78,0.30);
  border-radius: 4px;
  background: rgba(251,246,239,0.78);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  box-shadow: 0 10px 30px rgba(46,93,78,0.10);
}
.guest-dear {
  font-family: 'Marcellus', serif;
  font-size: clamp(9px, 2.3vw, 11px);
  letter-spacing: 6px;
  color: var(--rose-deep);
  display: block;
  margin-bottom: 2px;
}
.guest-name {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(34px, 9vw, 52px);
  color: var(--emerald);
  display: block;
  line-height: 1.05;
}
.guest-subtitle {
  font-family: 'EB Garamond', serif;
  font-style: italic;
  font-size: clamp(12px, 3vw, 14px);
  color: var(--ink);
  display: block;
  margin-top: 6px;
}

/* ─── LANDING ─── */
#landing {
  position: relative;
  width: 100%;
  height: 100svh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.landing-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 20px;
  width: 100%;
  max-width: 480px;
}

/* Wreath crest */
.crest { width: clamp(96px, 26vw, 132px); height: auto; margin: 0 auto 6px; display: block; }
.crest .crest-yr {
  font-family: 'Marcellus', serif;
  letter-spacing: 3px;
  fill: var(--emerald);
}

.eyebrow {
  font-family: 'Marcellus', serif;
  font-size: clamp(10px, 2.7vw, 12px);
  letter-spacing: 5px;
  color: var(--rose-deep);
  text-transform: uppercase;
}

.landing-names {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(60px, 17vw, 104px);
  color: var(--emerald);
  line-height: 0.92;
  margin: 6px 0 2px;
}
.landing-amp {
  display: block;
  font-family: 'EB Garamond', serif;
  font-style: italic;
  font-size: clamp(20px, 5vw, 30px);
  color: var(--rose);
  margin: 2px 0;
}

/* Botanical sprig divider */
.sprig {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin: 18px auto;
  color: var(--sage);
}
.sprig::before, .sprig::after {
  content: '';
  height: 1px;
  width: clamp(40px, 14vw, 70px);
  background: linear-gradient(to right, transparent, var(--sage));
}
.sprig::after { background: linear-gradient(to left, transparent, var(--sage)); }
.sprig svg { flex-shrink: 0; }

.landing-date {
  font-family: 'Marcellus', serif;
  font-size: clamp(12px, 3.4vw, 16px);
  color: var(--ink);
  letter-spacing: 6px;
  margin-bottom: 36px;
}

.open-btn {
  display: inline-block;
  padding: 15px 0;
  width: 76%;
  max-width: 280px;
  font-family: 'Marcellus', serif;
  font-size: clamp(11px, 3.2vw, 14px);
  letter-spacing: 3px;
  color: var(--ivory);
  background: linear-gradient(135deg, var(--emerald) 0%, var(--emerald-dk) 100%);
  border: none;
  border-radius: 2px;
  cursor: pointer;
  box-shadow: 0 12px 28px rgba(33,68,58,0.35);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  -webkit-appearance: none;
  position: relative;
}
.open-btn::after {
  content: '';
  position: absolute;
  inset: 4px;
  border: 1px solid rgba(251,246,239,0.40);
  border-radius: 1px;
  pointer-events: none;
}
.open-btn:active { transform: scale(0.97); box-shadow: 0 6px 16px rgba(33,68,58,0.3); }

.scroll-hint {
  position: absolute;
  bottom: 22px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7px;
  opacity: 0;
  transition: opacity 0.6s;
}
.scroll-hint.visible { opacity: 1; }
.scroll-hint span {
  font-family: 'Marcellus', serif;
  font-size: 9px; letter-spacing: 4px; color: var(--sage);
}
.scroll-arrow {
  width: 16px; height: 16px;
  border-right: 1.5px solid var(--sage);
  border-bottom: 1.5px solid var(--sage);
  transform: rotate(45deg);
  animation: bob 1.6s infinite;
}
@keyframes bob {
  0%,100% { transform: rotate(45deg) translateY(0); }
  50%     { transform: rotate(45deg) translateY(5px); }
}

/* ─── INVITATION SECTION ─── */
#invitation {
  position: relative;
  width: 100%;
  min-height: 100svh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 56px 16px 90px;
}

.card {
  position: relative;
  width: 100%;
  max-width: 500px;
  opacity: 0;
  transform: translateY(50px);
  transition: opacity 1s ease, transform 1s ease;
}
.card.revealed { opacity: 1; transform: translateY(0); }

.card-inner {
  position: relative;
  background: linear-gradient(180deg, #FFFDFA 0%, #FBF5EC 100%);
  border-radius: 6px;
  padding: 50px 24px 44px;
  text-align: center;
  box-shadow: 0 30px 70px rgba(33,68,58,0.22);
  border: 1px solid rgba(184,151,90,0.30);
  overflow: hidden;
}
/* Inner hairline frame */
.card-inner::before {
  content: '';
  position: absolute;
  inset: 12px;
  border: 1px solid rgba(143,174,155,0.45);
  border-radius: 3px;
  pointer-events: none;
}
/* Floral corner flourishes */
.corner {
  position: absolute;
  width: 64px; height: 64px;
  opacity: 0.75;
  pointer-events: none;
  color: var(--sage);
}
.corner.tl { top: 6px;  left: 6px; }
.corner.tr { top: 6px;  right: 6px; transform: scaleX(-1); }
.corner.bl { bottom: 6px; left: 6px; transform: scaleY(-1); }
.corner.br { bottom: 6px; right: 6px; transform: scale(-1,-1); }

.card-eyebrow {
  font-family: 'Marcellus', serif;
  font-size: clamp(9px, 2.6vw, 11px);
  letter-spacing: 5px;
  color: var(--rose-deep);
  text-transform: uppercase;
  position: relative;
}

.couple-names {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(48px, 13vw, 78px);
  color: var(--emerald);
  line-height: 1.0;
  margin: 8px 0 4px;
  position: relative;
}
.couple-amp {
  display: block;
  font-family: 'EB Garamond', serif;
  font-style: italic;
  font-size: clamp(18px, 4.6vw, 26px);
  color: var(--rose);
  margin: 0;
}

/* Family / lineage block */
.families {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 6px;
  margin: 16px auto 4px;
  max-width: 440px;
  position: relative;
}
.fam {
  font-family: 'EB Garamond', serif;
  line-height: 1.45;
}
.fam-name {
  font-family: 'Marcellus', serif;
  font-size: clamp(13px, 3.4vw, 16px);
  color: var(--emerald-dk);
  letter-spacing: 0.5px;
}
.fam-role {
  display: block;
  font-style: italic;
  font-size: clamp(11px, 2.9vw, 13px);
  color: var(--rose-deep);
  margin: 1px 0 3px;
}
.fam-detail {
  display: block;
  font-size: clamp(11.5px, 3vw, 13.5px);
  color: var(--ink);
}
.fam-house {
  display: block;
  font-style: italic;
  font-size: clamp(11px, 2.8vw, 13px);
  color: var(--sage);
}
.fam-join {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(26px, 7vw, 40px);
  color: var(--rose);
  line-height: 1;
}

.verse {
  font-family: 'EB Garamond', serif;
  font-size: clamp(13px, 3.4vw, 15.5px);
  color: var(--ink);
  line-height: 1.85;
  margin: 14px auto 4px;
  max-width: 400px;
  position: relative;
}
.scripture {
  font-style: italic;
  font-size: clamp(12px, 3.1vw, 14px);
  color: var(--emerald);
  margin-top: 10px;
}
.scripture cite {
  display: block;
  font-style: normal;
  font-family: 'Marcellus', serif;
  font-size: clamp(9px, 2.4vw, 11px);
  letter-spacing: 2px;
  color: var(--rose-deep);
  margin-top: 4px;
}

/* ── COUNTDOWN ── */
.countdown-wrap {
  margin: 24px auto 6px;
  max-width: 420px;
  position: relative;
}
.block-title {
  font-family: 'Marcellus', serif;
  font-size: clamp(10px, 2.7vw, 12px);
  letter-spacing: 4px;
  color: var(--rose-deep);
  text-transform: uppercase;
  margin-bottom: 14px;
}
.flip-clock {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
.flip-box {
  background: var(--ivory);
  border: 1px solid rgba(143,174,155,0.55);
  border-radius: 4px;
  padding: 14px 4px 9px;
  box-shadow: 0 6px 14px rgba(46,93,78,0.10), inset 0 0 0 3px rgba(255,255,255,0.6);
  position: relative;
}
.flip-box span {
  display: block;
  font-family: 'Marcellus', serif;
  font-size: clamp(22px, 6vw, 34px);
  color: var(--emerald);
  letter-spacing: 1px;
  transition: transform 0.18s ease;
}
.flip-box small {
  display: block;
  font-family: 'Marcellus', serif;
  font-size: clamp(7px, 1.9vw, 9px);
  color: var(--rose-deep);
  letter-spacing: 2px;
  margin-top: 5px;
  text-transform: uppercase;
}

/* ── EVENT CARDS ── */
.event-card {
  margin-top: 18px;
  padding: 20px 16px 18px;
  border: 1px solid rgba(184,151,90,0.45);
  border-radius: 5px;
  background: rgba(244,234,221,0.55);
  text-align: center;
  position: relative;
}
.event-card.is-wedding {
  background: rgba(46,93,78,0.07);
  border-color: rgba(46,93,78,0.40);
}
.event-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  margin-bottom: 10px;
}
.event-header svg { color: var(--emerald); flex-shrink: 0; }
.event-title {
  font-family: 'Marcellus', serif;
  font-size: clamp(11px, 3vw, 13px);
  letter-spacing: 3px;
  color: var(--emerald-dk);
  text-transform: uppercase;
}
.event-day {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(22px, 6vw, 30px);
  color: var(--rose);
  line-height: 1;
  margin-bottom: 2px;
}
.event-date {
  font-family: 'Marcellus', serif;
  font-size: clamp(14px, 3.7vw, 17px);
  color: var(--emerald-dk);
  letter-spacing: 1px;
}
.event-time {
  font-family: 'EB Garamond', serif;
  font-size: clamp(13px, 3.4vw, 15px);
  color: var(--ink);
  margin: 4px 0 6px;
}
.event-venue {
  font-family: 'EB Garamond', serif;
  font-style: italic;
  font-size: clamp(13px, 3.4vw, 15.5px);
  color: var(--emerald);
  line-height: 1.5;
}

.btn-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
  margin-top: 14px;
}

.map-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 12px;
  font-family: 'Marcellus', serif;
  font-size: clamp(9px, 2.5vw, 11px);
  letter-spacing: 2px;
  color: var(--ivory);
  background: linear-gradient(135deg, var(--rose) 0%, var(--rose-deep) 100%);
  border: none;
  border-radius: 30px;
  cursor: pointer;
  box-shadow: 0 5px 14px rgba(181,99,91,0.30);
  -webkit-appearance: none;
  transition: opacity 0.2s, transform 0.2s;
}
.map-btn:active { transform: scale(0.98); opacity: 0.9; }

/* ── ADD TO CALENDAR ── */
.calendar-wrap { position: relative; }
.cal-main-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 12px;
  font-family: 'Marcellus', serif;
  font-size: clamp(9px, 2.5vw, 11px);
  letter-spacing: 2px;
  color: var(--emerald-dk);
  background: var(--ivory);
  border: 1px solid rgba(46,93,78,0.45);
  border-radius: 30px;
  cursor: pointer;
  -webkit-appearance: none;
  transition: background 0.2s;
}
.cal-main-btn:active { background: var(--ivory-2); }
.cal-icon { display: inline-flex; align-items: center; }

.cal-dropdown {
  display: none;
  flex-direction: column;
  gap: 8px;
  margin-top: 8px;
  padding: 12px;
  border: 1px solid rgba(143,174,155,0.5);
  border-radius: 10px;
  background: rgba(255,253,250,0.97);
  backdrop-filter: blur(6px);
  animation: dropIn 0.25s ease forwards;
}
.cal-dropdown.open { display: flex; }
@keyframes dropIn {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}
.cal-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border: 1px solid rgba(143,174,155,0.4);
  border-radius: 30px;
  background: #fff;
  cursor: pointer;
  font-family: 'Marcellus', serif;
  font-size: clamp(9px, 2.5vw, 11px);
  letter-spacing: 1.5px;
  color: var(--emerald-dk);
  transition: background 0.15s;
  text-decoration: none;
  -webkit-appearance: none;
}
.cal-option:active { background: var(--ivory-2); }
.cal-option-icon {
  width: 22px; height: 22px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cal-google .cal-option-icon  { background: #fff; border: 1px solid #e0e0e0; }
.cal-apple  .cal-option-icon  { background: #000; }
.cal-outlook .cal-option-icon { background: #0078d4; }

/* ── FOOTER ── */
.card-footer {
  margin-top: 26px;
  position: relative;
}
.footer-line {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(26px, 7vw, 38px);
  color: var(--rose);
  line-height: 1;
}
.footer-note {
  font-family: 'Marcellus', serif;
  font-size: clamp(10px, 2.7vw, 12px);
  letter-spacing: 3px;
  color: var(--emerald);
  text-transform: uppercase;
  margin-top: 10px;
}

/* ── MUSIC BUTTON ── */
.music-btn {
  position: fixed;
  bottom: 18px;
  right: 18px;
  width: 50px;
  height: 50px;
  background: linear-gradient(135deg, var(--emerald) 0%, var(--emerald-dk) 100%);
  border: 1px solid rgba(184,151,90,0.6);
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 18px rgba(33,68,58,0.45);
  z-index: 100;
  -webkit-appearance: none;
  transition: transform 0.2s;
}
.music-btn:active { transform: scale(0.9); }
.music-btn svg { color: var(--ivory); }
.music-btn.playing { animation: pulseRing 2.4s ease-in-out infinite; }
@keyframes pulseRing {
  0%,100% { box-shadow: 0 6px 18px rgba(33,68,58,0.45), 0 0 0 0 rgba(206,128,121,0.45); }
  50%     { box-shadow: 0 6px 18px rgba(33,68,58,0.45), 0 0 0 10px rgba(206,128,121,0); }
}

@media (max-width: 360px) {
  .card-inner { padding: 44px 16px 40px; }
  .flip-clock { gap: 6px; }
  .families { gap: 4px; }
}

/* ── BRAND MARK ── */
.brand {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: center;
  padding: 0 16px 40px;
}
.brand img {
  width: clamp(44px, 12vw, 60px);
  height: auto;
  opacity: 0.85;
  border-radius: 10px;
}

@media (prefers-reduced-motion: reduce) {
  .petal { display: none; }
  .scroll-arrow, .music-btn.playing { animation: none; }
  html { scroll-behavior: auto; }
}
</style>
