/* ── FALLING PETALS ── */
(function(){
  const c = document.getElementById('petals');
  for(let i = 0; i < 26; i++){
    const p = document.createElement('div');
    p.className = 'petal';
    const s = Math.random() * 9 + 9;
    Object.assign(p.style, {
      width:  s + 'px',
      height: s + 'px',
      left:   (Math.random() * 100) + 'vw',
      animationDuration: (9 + Math.random() * 9) + 's',
      animationDelay: (Math.random() * 12) + 's',
      opacity: 0
    });
    if(Math.random() > 0.5) p.style.background = 'radial-gradient(circle at 30% 30%, #F2CFCB, #CE8079 78%)';
    c.appendChild(p);
