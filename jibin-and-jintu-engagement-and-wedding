<body>

<div id="petals"></div>

<!-- ─── LANDING ─── -->
<section id="landing">
  <div class="landing-content">

    <!-- Guest greeting — shown only when ?guest= is in the URL -->
    <div id="guest-banner">
      <div class="guest-pill">
        <span class="guest-dear">DEAR</span>
        <span class="guest-name" id="guest-name-display"></span>
        <span class="guest-subtitle">You are warmly invited to the wedding of Jibin &amp; Jintu</span>
      </div>
    </div>

    <!-- Wreath crest -->
    <svg class="crest" viewBox="0 0 140 140" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- cross -->
