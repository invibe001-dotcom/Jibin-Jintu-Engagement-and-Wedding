/* ── COUNTDOWN (to the wedding day) ── */
const weddingDate = new Date("August 24, 2026 10:30:00").getTime();
const pad = n => String(n).padStart(2, '0');
function flip(id, val){
  const el = document.getElementById(id);
  const v = pad(val);
  if(el.textContent !== v){
    el.style.transform = 'rotateX(90deg)';
    setTimeout(()=>{ el.textContent = v; el.style.transform = 'rotateX(0)'; }, 160);
  }
}
function updateCountdown(){
  const dist = weddingDate - Date.now();
  if(dist < 0){ ['days','hours','minutes','seconds'].forEach(id=>flip(id,0)); return; }
  flip('days',    Math.floor(dist / 86400000));
  flip('hours',   Math.floor((dist % 86400000) / 3600000));
  flip('minutes', Math.floor((dist % 3600000)  / 60000));
  flip('seconds', Math.floor((dist % 60000)    / 1000));
}
setInterval(updateCountdown, 1000);
updateCountdown();

/* ── MUSIC (HTML audio, starts at 0:17, loops from 0:17) ── */
const MUSIC_START = 17;
const music = document.getElementById('music');
let musicOn = false;

function setMusicUI(on){
  document.getElementById('musicBtn').classList.toggle('playing', on);
}

// Make the start point reliable even if metadata loads late
function seekToStart(){
  try { if(music.currentTime < MUSIC_START) music.currentTime = MUSIC_START; } catch(e){}
}

function startMusic(){
  const begin = () => {
    seekToStart();
    music.play().then(()=>{ musicOn = true; setMusicUI(true); }).catch(()=>{});
  };
  if(music.readyState >= 1){ begin(); }
  else { music.addEventListener('loadedmetadata', begin, { once: true }); music.load(); }
}

function toggleMusic(){
  if(musicOn){ music.pause(); musicOn = false; setMusicUI(false); }
  else { startMusic(); }
}

// Loop back to the 17s mark instead of the very beginning
music.addEventListener('ended', () => {
  music.currentTime = MUSIC_START;
  music.play().catch(()=>{});
});
</script>
