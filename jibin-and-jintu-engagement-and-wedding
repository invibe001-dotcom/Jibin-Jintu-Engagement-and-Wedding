<script>
/* ───────── EVENT DATA (edit times here if they change) ─────────
   Times are stored in UTC. IST = UTC + 5:30.
   Engagement placeholder: 4:30 PM IST  → 11:00 UTC
   Wedding   placeholder: 10:30 AM IST  → 05:00 UTC                 */
const EVENTS = {
  eng: {
    title:    'Engagement of Jibin Philip & Jintu P Biju',
    location: 'Sacred Heart Church, Mampoil',
    details:  'Join us for the engagement ceremony of Jibin Philip and Jintu P Biju.',
    startUTC: '20260820T050000Z',
    endUTC:   '20260820T070000Z',
    startISO: '2026-08-20T10:30:00',
    endISO:   '2026-08-20T12:30:00',
    file:     'jibin-jintu-engagement.ics'
  },
  wed: {
    title:    'Wedding of Jibin Philip & Jintu P Biju',
    location: 'Infant Jesus Church, Cheekadu',
    details:  'You are cordially invited to celebrate the wedding of Jibin Philip and Jintu P Biju.',
    startUTC: '20260824T050000Z',
    endUTC:   '20260824T070000Z',
    startISO: '2026-08-24T10:30:00',
    endISO:   '2026-08-24T12:30:00',
    file:     'jibin-jintu-wedding.ics'
  }
};

function buildGoogleLink(ev){
  const p = new URLSearchParams({
    action: 'TEMPLATE',
    text: ev.title,
    dates: ev.startUTC + '/' + ev.endUTC,
    details: ev.details,
    location: ev.location
  });
  return 'https://calendar.google.com/calendar/render?' + p.toString();
}
function buildOutlookLink(ev){
  const p = new URLSearchParams({
    path: '/calendar/action/compose',
    rru: 'addevent',
    subject: ev.title,
    startdt: ev.startISO,
    enddt: ev.endISO,
    body: ev.details,
    location: ev.location
  });
  return 'https://outlook.live.com/calendar/0/deeplink/compose?' + p.toString();
}
function downloadICS(key){
  const ev = EVENTS[key];
  const ics = [
    'BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Jibin & Jintu Wedding//EN',
    'CALSCALE:GREGORIAN','METHOD:PUBLISH','BEGIN:VEVENT',
    'DTSTART:' + ev.startUTC,'DTEND:' + ev.endUTC,
    'SUMMARY:' + ev.title,'DESCRIPTION:' + ev.details,'LOCATION:' + ev.location,
    'STATUS:CONFIRMED','SEQUENCE:0','END:VEVENT','END:VCALENDAR'
  ].join('\r\n');
  const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
  const url  = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = ev.file;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

document.getElementById('gcal-eng').href = buildGoogleLink(EVENTS.eng);
document.getElementById('ocal-eng').href = buildOutlookLink(EVENTS.eng);
document.getElementById('gcal-wed').href = buildGoogleLink(EVENTS.wed);
document.getElementById('ocal-wed').href = buildOutlookLink(EVENTS.wed);

function toggleCalendar(key){
  const target = document.getElementById('cal-' + key);
  document.querySelectorAll('.cal-dropdown').forEach(d => { if(d !== target) d.classList.remove('open'); });
  target.classList.toggle('open');
}
document.addEventListener('click', function(e){
  if(!e.target.closest('.calendar-wrap')){
    document.querySelectorAll('.cal-dropdown').forEach(d => d.classList.remove('open'));
  }
});

