let opened = false;
function openInvitation(){
  if(opened) return;
  opened = true;
  document.getElementById('scrollHint').classList.add('visible');
  setTimeout(()=>{ document.getElementById('invitation').scrollIntoView({ behavior: 'smooth' }); }, 150);
